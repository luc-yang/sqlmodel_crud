    async def set_config(self, db_config: DatabaseConfig) -> None:
        """更新数据库配置并重置会话工厂。"""
        if self._engine is not None:
            await self.close()
        self.db_config = db_config

    @property
    def engine(self):
        """获取异步数据库引擎。"""
        if self._engine is None:
            self._engine = create_async_engine(
                self.db_config.database_url,
                echo={% if config.echo_sql %}True{% else %}False{% endif %},
                pool_size={{ config.pool_size }},
                max_overflow={{ config.max_overflow }},
            )
        return self._engine

    @property
    def session_maker(self) -> async_sessionmaker[AsyncSession]:
        """获取异步会话工厂。"""
        if self._session_maker is None:
            self._session_maker = async_sessionmaker(
                self.engine,
                expire_on_commit=False,
                autoflush=False,
            )
        return self._session_maker

    @asynccontextmanager
    async def get_async_session(self) -> AsyncGenerator[AsyncSession, None]:
        """获取异步数据库会话。"""
        session = self.session_maker()
        try:
            yield session
            await session.commit()
        except Exception:
            await session.rollback()
            raise
        finally:
            await session.close()

    async def init_database(self) -> None:
        """初始化数据库。"""
        initializer = DatabaseInitializer(self.db_config)
        await initializer.init_database(self.engine)

    async def close(self) -> None:
        """关闭异步数据库连接。"""
        if self._engine is not None:
            await self._engine.dispose()
            self._engine = None
            self._session_maker = None


